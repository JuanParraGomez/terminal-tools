APP_NAME=terminal-tools
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8090

DATA_DIR=./data
LOGS_DIR=./data/logs
DB_PATH=./data/terminal_tools.db
CONTEXT_DIR=./data/context
CONTEXT_TTL_SECONDS=900
TRASH_DIR=/home/juan/Documents/terminal-tools/data/trash
TRASH_TTL_DAYS=7
LANGGRAPH_AGENT_REPO_ROOT=/home/juan/Documents/langgraph-agent-server
LANGGRAPH_AGENT_REPO_TESTS_DIR=/home/juan/Documents/langgraph-agent-server/tests
LANGGRAPH_AGENT_REPO_TRASH_DIR=/home/juan/Documents/langgraph-agent-server/data/trash

DEFAULT_TIMEOUT_SECONDS=120
MAX_OUTPUT_CHARS=50000

ALLOWED_WORKDIRS=/home/juan/Documents,/tmp
ALLOWED_SCRIPT_DIRS=/home/juan/Documents/scripts/backup,/home/juan/Documents/scripts/deploy,/home/juan/Documents/scripts/maintenance

COPILOT_BIN=copilot
CODEX_BIN=codex
CLAUDE_BIN=claude
GCLOUD_BIN=gcloud
GEMINI_CLI_BIN=gemini

COPILOT_MODEL_CHEAP_A=x0
COPILOT_MODEL_CHEAP_B=x0.33
COPILOT_MODEL_PLAN=x1
COPILOT_CLI_MODEL_CHEAP_A=
COPILOT_CLI_MODEL_CHEAP_B=
COPILOT_CLI_MODEL_PLAN=claude-sonnet-4.6
CLAUDE_MODEL_REVIEW=x1

ENABLE_GEMINI_CLI=true
ENABLE_GCLOUD=true
ENABLE_CODEX=true
ENABLE_COPILOT=true
ENABLE_CLAUDE=true
ENABLE_LANGGRAPH_AGENT_SERVER=true

LANGGRAPH_AGENT_SERVER_BASE_URL=http://host.docker.internal:8070
LANGGRAPH_AGENT_SERVER_MCP_URL=http://host.docker.internal:8070/mcp/tools

AUTO_REFRESH_CONTEXT_ON_STALE=true

MCP_TRANSPORT=streamable-http
MCP_HOST=127.0.0.1
MCP_PORT=8091
